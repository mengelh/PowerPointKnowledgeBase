http:
  routers:
    traefik-dashboard:
      rule: "PathPrefix(`/traefik`)"
      entryPoints:
        - websecure
      service: api@internal
      tls: {}
      middlewares:
        - traefik-strip-prefix@file
        # - authentik-forward-auth@file  # re-enable after Authentik is configured

  middlewares:
    traefik-strip-prefix:
      stripPrefix:
        prefixes:
          - "/traefik"
