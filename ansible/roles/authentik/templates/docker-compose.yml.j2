services:
  postgresql:
    image: docker.io/library/postgres:16-alpine
    container_name: authentik-postgresql
    restart: unless-stopped
    environment:
      POSTGRES_PASSWORD: "{{ vault_pg_password }}"
      POSTGRES_USER: "{{ pg_user }}"
      POSTGRES_DB: "{{ pg_db }}"
    volumes:
      - postgresql_data:/var/lib/postgresql/data
    networks:
      - authentik_internal
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{ pg_user }} -d {{ pg_db }}"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 30s

  valkey:
    image: docker.io/valkey/valkey:8-alpine
    container_name: authentik-valkey
    restart: unless-stopped
    command: --save 60 1 --loglevel warning
    volumes:
      - valkey_data:/data
    networks:
      - authentik_internal
    healthcheck:
      test: ["CMD-SHELL", "valkey-cli ping"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 10s

  authentik-server:
    image: {{ authentik_image }}
    container_name: authentik-server
    restart: unless-stopped
    command: server
    environment: &authentik-env
      AUTHENTIK_REDIS__HOST: valkey
      AUTHENTIK_POSTGRESQL__HOST: postgresql
      AUTHENTIK_POSTGRESQL__USER: "{{ pg_user }}"
      AUTHENTIK_POSTGRESQL__NAME: "{{ pg_db }}"
      AUTHENTIK_POSTGRESQL__PASSWORD: "{{ vault_pg_password }}"
      AUTHENTIK_SECRET_KEY: "{{ vault_authentik_secret_key }}"
      AUTHENTIK_WEB__PATH: "{{ authentik_web_path }}"
      AUTHENTIK_COOKIE_DOMAIN: "{{ authentik_cookie_domain }}"
      AUTHENTIK_LISTEN__PROXY_TRUSTED_CIDRS: "172.16.0.0/12,10.0.0.0/8"
    volumes:
      - {{ authentik_compose_dir }}/media:/media
      - {{ authentik_compose_dir }}/custom-templates:/templates
    networks:
      - proxy
      - authentik_internal
    depends_on:
      postgresql:
        condition: service_healthy
      valkey:
        condition: service_healthy
    healthcheck:
      test: ["CMD-SHELL", "wget -qO- http://localhost:9000/-/health/ready/ || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 60s
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.authentik.rule=PathPrefix(`{{ authentik_web_path }}`)"
      - "traefik.http.routers.authentik.entrypoints=websecure"
      - "traefik.http.routers.authentik.tls=true"
      - "traefik.http.services.authentik.loadbalancer.server.port=9000"
      - "traefik.docker.network=proxy"

  authentik-worker:
    image: {{ authentik_image }}
    container_name: authentik-worker
    restart: unless-stopped
    command: worker
    environment: *authentik-env
    user: root
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock
      - {{ authentik_compose_dir }}/media:/media
      - {{ authentik_compose_dir }}/certs:/certs
      - {{ authentik_compose_dir }}/custom-templates:/templates
    networks:
      - authentik_internal
    depends_on:
      postgresql:
        condition: service_healthy
      valkey:
        condition: service_healthy

volumes:
  postgresql_data:
    driver: local
  valkey_data:
    driver: local

networks:
  proxy:
    external: true
    name: proxy
  authentik_internal:
    driver: bridge
    internal: true
